generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  MEMBER
}

enum SessionType {
  MORNING
  NIGHT
}

enum DominantEmotion {
  CALM
  ANXIOUS
  ANGRY
  SAD
  EXCITED
  TIRED
  EMPTY
  GRATEFUL
  PRESSURED
  STABLE
}

enum AlignmentFeeling {
  ALIGNED
  NEUTRAL
  NOT_ALIGNED
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  role         Role
  activeStatus Boolean     @default(true)
  teamMemberId String?     @unique
  teamMember   TeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model TeamMember {
  id                 String               @id @default(cuid())
  fullName           String
  email              String               @unique
  divisionOrRole     String
  activeStatus       Boolean              @default(true)
  user               User?
  humanDesignProfile HumanDesignProfile?
  emotionLogs        EmotionLog[]
  recommendations    Recommendation[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model HumanDesignProfile {
  id              String     @id @default(cuid())
  teamMemberId    String     @unique
  teamMember      TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  type            String?
  authority       String?
  profile         String?
  signature       String?
  notSelfTheme    String?
  emotionalNotes  String?    @db.Text
  decisionStyle   String?    @db.Text
  triggerNotes    String?    @db.Text
  ravechartFileUrl String?
  ownerSummaryText String?   @db.Text
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model EmotionLog {
  id               String            @id @default(cuid())
  teamMemberId     String
  teamMember       TeamMember        @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  date             DateTime          @db.Date
  sessionType      SessionType
  emotionScore     Int
  energyScore      Int
  stressScore      Int
  clarityScore     Int
  dominantEmotion  DominantEmotion
  triggerText      String?           @db.Text
  note             String?           @db.Text
  alignmentFeeling AlignmentFeeling
  recommendation   Recommendation?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([teamMemberId, date, sessionType])
  @@index([date])
  @@index([teamMemberId, date])
}

model Recommendation {
  id          String     @id @default(cuid())
  teamMemberId String
  teamMember  TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  emotionLogId String    @unique
  emotionLog  EmotionLog @relation(fields: [emotionLogId], references: [id], onDelete: Cascade)
  title       String
  body        String     @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
